# ───────────────────────── Secrets — NEVER commit ─────────────────────────
.secrets/
*.key
*.pem
.env
.env.*

# ───────────────────────── Dependencies / build ───────────────────────────
node_modules/
dist/
out/
release/
build/

# ───────────────────────── Runtime / logs ─────────────────────────────────
# DevPet keeps its config + diary in the OS userData dir (outside the repo),
# so there's nothing runtime to ignore here — just stray logs.
# (NOTE: do NOT add a bare `diary/` or `config.json` here — it would also match
#  the source dirs src/main/diary and src/renderer/diary.)
*.log
_petlog.txt

# ───────────────────────── Raw / WIP asset material ────────────────────────
assets/_*/
assets/source/
Wesen/
samples-voice/

# ───────────────────────── OS / editor cruft ──────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~
